# ============================================================
# Routinely 로컬 개발 환경 시크릿 템플릿
#
# 사용법: cp infra/.env.example infra/.env  →  값을 채운다
# ⚠️  .env 파일은 절대 Git에 커밋하지 마세요. (.gitignore 처리됨)
# ============================================================

# ── PostgreSQL ────────────────────────────────────────────────
# docker-compose.yml 의 POSTGRES_PASSWORD 로 사용된다.
DB_PASSWORD=

# ── JWT ───────────────────────────────────────────────────────
# Gateway 에서 JWT 서명 검증에 사용한다 (ADR-0006).
# 생성 예: openssl rand -base64 32
JWT_SECRET=

# ── Gateway 내부 통신 시크릿 ──────────────────────────────────
# X-Gateway-Secret 헤더 값. 내부 서비스가 직접 호출 여부 검증에 사용 (ADR-0019).
# 생성 예: openssl rand -hex 32
GATEWAY_SECRET=

# ── Grafana 관리자 비밀번호 ───────────────────────────────────
# 설정하지 않으면 기본값 'admin' 이 적용된다.
GRAFANA_PASSWORD=

# ── registry-service (prod 전용) ──────────────────────────────
# prod 프로파일에서 eureka.instance.hostname 으로 사용된다.
# 로컬(local 프로파일)에서는 localhost 로 고정되므로 설정 불필요.
EUREKA_HOST=
